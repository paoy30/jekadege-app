// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  password  String
  invoices  Invoice[]
  links     Link[]
  posts     Post[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
}

model Invoice {
  id                  String          @id
  title               String
  orderType           String?
  customerName        String?
  customerPhone       String?
  customerAddress     String?
  status              InvoiceStatus   @default(DALAM_ANTRIAN)
  notes               String?
  totalPrice          Decimal         @default(0)
  amountPaid          Decimal         @default(0)
  estimatedFinishedAt DateTime?

  // FIELD BARU: Bukti Pembayaran
  paymentProof        String?

  items               InvoiceItem[]
  history             InvoiceHistory[]
  createdBy           User            @relation(fields: [userId], references: [id])
  userId              String

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

model InvoiceItem {
  id          String   @id @default(cuid())
  description String
  quantity    Decimal
  unitPrice   Decimal
  amount      Decimal
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InvoiceHistory {
  id        String        @id @default(cuid())
  status    InvoiceStatus
  note      String?
  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  createdAt DateTime      @default(now())
}

model Link {
  id        String   @id @default(cuid())
  title     String
  url       String
  icon      String   @default("Default")
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
}

enum InvoiceStatus {
  DALAM_ANTRIAN
  DIPROSES
  DIANTAR
  SELESAI
  BATAL
}

model Post {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
}

model GallerySection {
  id          String         @id @unique
  title       String         @unique
  category    String
  coverImage  String
  description String?        @db.Text
  images      GalleryImage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model GalleryImage {
  id            String         @id @default(cuid())
  imageUrl      String
  altText       String?
  priceEstimate Decimal?       @default(0)
  section       GallerySection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  message   String   @db.Text
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}